ppassword =12345

while True:
    password = input("Enter Password or type exit to terminate :- ")
    if password.lower()=="exit":
        print("terminated")
        break
    
    try:
        password=int(password)
        if password == ppassword:
            print("Login Successful")
            break
        print("wrong password ,pleasr try again or type exit to terminate")
    except:
        print("please enter Numerical value only or type exit to terminate")

        
